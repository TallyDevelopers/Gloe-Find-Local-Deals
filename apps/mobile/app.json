{
  "expo": {
    "name": "Gloe",
    "slug": "gloe",
    "version": "0.0.1",
    "orientation": "portrait",
    "scheme": "gloe",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FAF5F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gloe.app",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Gloe uses your location to show aesthetic deals near you.",
        "NSFaceIDUsageDescription": "Gloē uses Face ID to sign you in securely.",
        "LSApplicationQueriesSchemes": [
          "comgooglemaps",
          "waze"
        ]
      }
    },
    "android": {
      "package": "com.gloe.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A130F"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Gloē uses Face ID to sign you in securely."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Gloe uses your location to show aesthetic deals near you."
        }
      ],
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.gloe.app",
          "enableGooglePay": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Gloe needs access to your photos so you can attach pictures to reviews.",
          "cameraPermission": "Gloe needs camera access so you can take a photo for your review."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#1A130F"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
